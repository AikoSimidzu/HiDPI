<UserControl x:Class="HiDPI.TGProxyForm"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HiDPI"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="#121111">
    
    <Grid RowDefinitions="30, 30, 30, 40, 5, 40, *">
        <Label Content="IP: 127.0.0.1" Foreground="White" FontSize="13"/>
        <Label Content="Port: 1080" Grid.Row="1" Foreground="White" FontSize="13"/>
        <Label Content="{Binding DataContext.TgProxyIsStart, RelativeSource={RelativeSource AncestorType=Window }}" Grid.Row="2" Foreground="White" FontSize="13"/>
        <Button x:Name="Connect" Command="{Binding DataContext.StartTgProxy, RelativeSource={RelativeSource AncestorType=Window }}" Margin="0 0 207 0" Content="Запустить" FontSize="13" FontWeight="Medium" Width="200" Grid.Row="3"/>
        <Button x:Name="Stop" Command="{Binding DataContext.StopTgProxy, RelativeSource={RelativeSource AncestorType=Window }}" Margin="207 0 0 0" Content="Остановить" FontSize="13" FontWeight="Medium" Width="200" Grid.Row="3"/>
        <Button x:Name="AddToTG" Click="AddToTG_Click" Content="Подключиться" FontSize="13" FontWeight="Medium" Width="200" Grid.Row="5"/>
    </Grid>
</UserControl>
