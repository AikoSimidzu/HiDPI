<Application x:Class="HiDPI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:HiDPI"
             xmlns:viewModel="clr-namespace:HiDPI.MVVM.ViewModel"
             StartupUri="MainWindow.xaml">
    
    <Application.Resources>
        <ResourceDictionary>
            <DataTemplate DataType="{x:Type viewModel:ConnectionsViewModel}">
                <local:ConnectionsForm/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type viewModel:LogsViewModel}">
                <local:logsForm/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type viewModel:SettingsViewModel}">
                <local:SettingsForm/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type viewModel:DonateViewModel}">
                <local:DonateForm/>
            </DataTemplate>

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/buttons.xaml"/>
                <ResourceDictionary Source="/Styles/contextStyle.xaml"/>
                <ResourceDictionary Source="/Styles/containersStyle.xaml"/>
                <ResourceDictionary Source="/Styles/dGrid.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
