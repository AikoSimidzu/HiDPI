<UserControl x:Class="HiDPI.SettingsForm"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HiDPI"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="#121111"
             Loaded="UserControl_Loaded">

    <Grid RowDefinitions="30, 30, 30, 30, *, 40" ColumnDefinitions="*, *, *">
        <Label Content="Автозапуск" Foreground="White" FontSize="13"/>
        <CheckBox Margin="0 0 40 0" Command="{Binding DataContext.SetStartUp, RelativeSource={RelativeSource AncestorType=Window }}" IsChecked="{Binding DataContext.AutoStartUp, RelativeSource={RelativeSource AncestorType=Window }}" Foreground="White"/>

        <Label Grid.Row="1" Content="Подключаться автоматически" Foreground="White" FontSize="13"/>
        <CheckBox Grid.Row="1" Command="{Binding DataContext.SetAutoConnect, RelativeSource={RelativeSource AncestorType=Window }}" IsChecked="{Binding DataContext.AutoConnect, RelativeSource={RelativeSource AncestorType=Window }}" Width="50" Margin="180 0 0 0" Foreground="White"/>

        <Label Grid.Row="2" Content="Автоматически перезапускать Zapret2 при ошибках" Foreground="White" Grid.ColumnSpan="2" FontSize="13"/>
        <CheckBox Grid.Row="2" Command="{Binding DataContext.SetAutoRestartIfError, RelativeSource={RelativeSource AncestorType=Window }}" IsChecked="{Binding DataContext.AutoRestartIfError, RelativeSource={RelativeSource AncestorType=Window }}" Grid.Column="1" Width="50" Foreground="White" Margin="0 0 50 0"/>

        <Label Grid.Row="3" Content="Автоматически запускать TG прокси" Foreground="White" FontSize="13"/>
        <CheckBox Grid.Row="3" Grid.Column="1" Width="50" Foreground="White" Command="{Binding DataContext.SetAutoStartTGProxy, RelativeSource={RelativeSource AncestorType=Window }}" IsChecked="{Binding DataContext.TgProxyAutoStart, RelativeSource={RelativeSource AncestorType=Window }}" HorizontalAlignment="Left"/>

        <Grid ColumnDefinitions="*, *, *" Grid.Row="5" Grid.ColumnSpan="3">
            <Label x:Name="VersionNow" Grid.Row="4" Foreground="White" FontSize="15" FontWeight="DemiBold" Content="Текущая версия: "/>
            <Label x:Name="ActualVersion" Grid.Row="4" Foreground="White" FontSize="15" FontWeight="DemiBold" Grid.Column="1" Content="Актуальная версия: "/>
            <Button x:Name="Update" Click="Update_Click" Grid.Row="4" Grid.Column="2" Content="Обновить" FontSize="15" FontWeight="DemiBold" Width="200" Height="40"/>
        </Grid>        
    </Grid>
</UserControl>
