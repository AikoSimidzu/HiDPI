<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TGProxy.MainPage"
             Loaded="ContentPage_Loaded"
             Background="#141414"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">

            <Grid RowDefinitions="30, 40, 8, 40, *">
                <Button x:Name="startProxy"
                    Grid.Row="1"
                    Background="#2D2D2D"
                    Text="Запустить"
                    TextColor="White"
                    Clicked="startProxy_Clicked"/>

                <Button x:Name="connectToProxy"
                    Grid.Row="3"
                    Background="#2D2D2D"
                    Text="Подключить"
                    TextColor="White"
                    Clicked="connectToProxy_Clicked"/>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
